    const ensureSeeded = async () => {
      const probe = await db.collection("announcements").doc("sanliurfa-genel-kurul").get();
      if (probe.exists) return;
      const batch = db.batch();
      seedAnnouncements.forEach((item) => {
        const ref = db.collection("announcements").doc(item.id);
        batch.set(
          ref,
          {
            title: item.title,
            body: item.body,
            coverUrl: item.coverUrl,
            images: item.images,
            order: item.order,
            eventDate: item.eventDate || "",
            publishedAt: firebase.firestore.FieldValue.serverTimestamp(),
            createdAt: firebase.firestore.FieldValue.serverTimestamp()
          },
          { merge: true }
        );
      });
      await batch.commit();
    };

    const bindAuth = () => {
      try {
        const firebaseRefs = initFirebase();
        auth = firebaseRefs.auth;
        db = firebaseRefs.db;
        storage = firebaseRefs.storage;
        auth.setPersistence(firebase.auth.Auth.Persistence.LOCAL);
      } catch (error) {
        showError("Firebase yüklenemedi. Lütfen ağ ve Firebase ayarlarını kontrol edin.");
        return;
      }

      loginBtn?.addEventListener("click", async () => {
        authError.classList.add("hidden");
        showAuthStatus("Giriş penceresi açılıyor...");
        try {
          const provider = new firebase.auth.GoogleAuthProvider();
          await auth.signInWithPopup(provider);
        } catch (error) {
          const code = error?.code || "";
          if (code === "auth/popup-blocked" || code === "auth/operation-not-supported-in-this-environment") {
            showAuthStatus("Popup engellendi. Yönlendirme ile giriş yapılıyor...");
            await auth.signInWithRedirect(new firebase.auth.GoogleAuthProvider());
            return;
          }
          showError(`Giriş başarısız: ${error?.message || code || "Bilinmeyen hata"}`);
        }
      });

      auth.getRedirectResult().catch((error) => {
        if (!error) return;
        showError(`Giriş başarısız: ${error?.message || error?.code || "Bilinmeyen hata"}`);
      });

      logoutBtn?.addEventListener("click", async () => {
        await auth.signOut();
      });

      auth.onAuthStateChanged((user) => {
        if (!user) {
          authCard?.classList.remove("hidden");
          adminPanel?.classList.add("hidden");
          return;
        }
        if (user.email !== allowedEmail) {
          showError("Bu hesap yetkili değil. Lütfen doğru hesapla giriş yapın.");
          auth.signOut();
          return;
        }
        authCard?.classList.add("hidden");
        adminPanel?.classList.remove("hidden");
        ensureSeeded().then(loadAnnouncements);
        ensureBoardSeeded()
          .catch(() => {
            if (boardStatus) boardStatus.textContent = "Yönetim kurulu yüklenemedi.";
          })
          .finally(() => {
            loadBoard();
          });
      });
    };

