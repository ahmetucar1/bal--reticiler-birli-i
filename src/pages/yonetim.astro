    membersWrap?.addEventListener("input", (event) => {
      const target = event.target;
      const row = target.closest("[data-member-id]");
      if (!row) return;
      const member = memberDrafts.find((entry) => entry.id === row.dataset.memberId);
      if (!member) return;
      const field = target.dataset.field;
      if (!field) return;
      if (field === "name") {
        member.name = target.value;
        const placeholder = row.querySelector("[data-member-placeholder]");
        if (placeholder && !member.photoUrl && !member.file) {
          placeholder.textContent = getInitials(member.name) || "YK";
        }
      }
      if (field === "role") {
        member.role = target.value;
      }
    });

    membersWrap?.addEventListener("change", (event) => {
      const target = event.target;
      const row = target.closest("[data-member-id]");
      if (!row) return;
      const member = memberDrafts.find((entry) => entry.id === row.dataset.memberId);
      if (!member) return;
      const field = target.dataset.field;
      if (field !== "photo") return;
      const file = target.files?.[0] || null;
      if (member.previewUrl) {
        URL.revokeObjectURL(member.previewUrl);
        member.previewUrl = "";
      }
      member.file = file;
      const box = row.querySelector("[data-photo-box]");
      if (!box) return;
      if (file) {
        member.previewUrl = URL.createObjectURL(file);
        box.innerHTML = `<img src="${escapeHtml(member.previewUrl)}" alt="${escapeHtml(member.name)}" class="h-full w-full object-cover" data-member-photo />`;
        return;
      }
      if (member.photoUrl) {
        box.innerHTML = `<img src="${escapeHtml(member.photoUrl)}" alt="${escapeHtml(member.name)}" class="h-full w-full object-cover" data-member-photo />`;
      } else {
        const initials = getInitials(member.name) || "YK";
        box.innerHTML = `<div class="grid h-full w-full place-items-center bg-sand-100 text-xs font-semibold text-slate-500" data-member-placeholder>${escapeHtml(initials)}</div>`;
      }
    });

    membersWrap?.addEventListener("click", (event) => {
      const button = event.target.closest("button");
      if (!button || button.dataset.action !== "remove") return;
      const row = button.closest("[data-member-id]");
      if (!row) return;
      const targetId = row.dataset.memberId;
      const targetMember = memberDrafts.find((entry) => entry.id === targetId);
      if (targetMember?.previewUrl) {
        URL.revokeObjectURL(targetMember.previewUrl);
      }
      memberDrafts = memberDrafts.filter((entry) => entry.id !== targetId);
      renderMembers();
    });

