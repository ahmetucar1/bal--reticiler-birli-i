---
import { siteConfig } from '../config/site';
---

<footer class="border-t border-sand-200 bg-gradient-to-b from-white via-sand-50 to-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 space-y-10">
    <div class="grid gap-10 lg:grid-cols-12">
      <!-- Brand -->
      <div class="lg:col-span-5 space-y-4">
        <div class="flex items-center gap-3">
          <img src="/assets/brand/logo-128.png" alt={siteConfig.brandName} class="h-11 w-auto" loading="lazy" decoding="async" />
          <div>
            <p class="text-base font-semibold text-slate-900">{siteConfig.brandName}</p>
            <p class="text-xs text-slate-600">Türkiye arıcılarının merkezi sesi</p>
          </div>
        </div>
        <p class="text-sm text-slate-700 max-w-lg">{siteConfig.description}</p>
        <div class="flex flex-wrap gap-2">
          <a href="/duyurular" class="inline-flex items-center gap-2 rounded-full bg-pine-600 px-4 py-2 text-xs font-semibold text-white shadow-card transition hover:-translate-y-0.5 hover:bg-pine-700 focus-visible:shadow-focus" style="color:#fff;">
            Duyurular
          </a>
          <a href="/iletisim" class="inline-flex items-center gap-2 rounded-full border border-pine-200 bg-white px-4 py-2 text-xs font-semibold text-pine-800 shadow-card transition hover:-translate-y-0.5 hover:border-pine-300">
            İletişim
          </a>
        </div>
      </div>

      <!-- Sitemap -->
      <div class="lg:col-span-3 space-y-3">
        <p class="text-sm font-semibold text-slate-900">Site haritası</p>
        <nav class="grid grid-cols-2 gap-2 text-sm">
          {siteConfig.nav.map((item) => (
            <a class="rounded-lg px-2.5 py-1.5 text-slate-800 hover:bg-sand-100 transition" href={item.href}>{item.title}</a>
          ))}
          <a class="rounded-lg px-2.5 py-1.5 text-slate-800 hover:bg-sand-100 transition" href="/gizlilik">Gizlilik</a>
        </nav>
      </div>

      <!-- Contact Card -->
      <div class="lg:col-span-4">
        <div class="rounded-2xl border border-sand-200 bg-white/95 p-5 shadow-card space-y-3">
          <p class="text-sm font-semibold text-slate-900">İletişim</p>

          {siteConfig.contacts.phone && (
            <a class="contact-row" href={`tel:${siteConfig.contacts.phone.replace(/\\s+/g, '')}`}>
              <span class="contact-icon">☎</span>
              <div>
                <p class="contact-label">Telefon</p>
                <p class="contact-value">{siteConfig.contacts.phone}</p>
              </div>
            </a>
          )}

          {siteConfig.contacts.email && (
            <a class="contact-row" href={`mailto:${siteConfig.contacts.email}`}>
              <span class="contact-icon">✉</span>
              <div>
                <p class="contact-label">E-posta</p>
                <p class="contact-value break-all">{siteConfig.contacts.email}</p>
              </div>
            </a>
          )}

          <a class="contact-row" href="mailto:balureticilerimerkezbirligi@hs01.kep.tr">
            <span class="contact-icon">✉</span>
            <div>
              <p class="contact-label">KEP</p>
              <p class="contact-value break-all">balureticilerimerkezbirligi@hs01.kep.tr</p>
            </div>
          </a>

          <div class="contact-row cursor-default">
            <span class="contact-icon">📍</span>
            <div>
              <p class="contact-label">Adres</p>
              <p class="contact-value leading-snug">
                Ehlibeyt Mahallesi 1242. Cad. 2/22<br />Çankaya / Ankara
              </p>
            </div>
          </div>

          <a
            class="contact-row contact-cta"
            href="https://www.google.com/maps/dir/?api=1&destination=Ehlibeyt%20Mahallesi%201242.%20Cad.%202%2F22%20%C3%87ankaya%20Ankara"
          >
            <span class="contact-icon">🗺</span>
            <div>
              <p class="contact-label">Haritada aç</p>
              <p class="contact-value text-pine-800">Yol tarifi başlat</p>
            </div>
          </a>

          {(siteConfig.socials.linkedin || siteConfig.socials.instagram || siteConfig.socials.twitter || siteConfig.socials.facebook || siteConfig.socials.youtube) && (
            <div class="pt-1 space-y-1">
              <p class="contact-label text-pine-700">Sosyal medya</p>
              <div class="flex flex-wrap gap-2">
                {siteConfig.socials.instagram && (
                  <a href={siteConfig.socials.instagram} class="social-pill social-ig" aria-label="Instagram">
                    <span class="social-mark">IG</span>
                    <span class="social-text">Instagram</span>
                  </a>
                )}
                {siteConfig.socials.twitter && (
                  <a href={siteConfig.socials.twitter} class="social-pill social-x" aria-label="X">
                    <span class="social-mark">X</span>
                    <span class="social-text">X</span>
                  </a>
                )}
                {siteConfig.socials.linkedin && <a href={siteConfig.socials.linkedin} class="social-pill" aria-label="LinkedIn">in</a>}
                {siteConfig.socials.facebook && (
                  <a href={siteConfig.socials.facebook} class="social-pill social-fb" aria-label="Facebook">
                    <span class="social-mark">FB</span>
                    <span class="social-text">Facebook</span>
                  </a>
                )}
                {siteConfig.socials.youtube && <a href={siteConfig.socials.youtube} class="social-pill" aria-label="YouTube">YT</a>}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-2 border-t border-sand-200 pt-4 text-xs text-slate-600 items-center text-center">
      <p class="w-full text-center">© {new Date().getFullYear()} {siteConfig.name}. Tüm hakları saklıdır.</p>
    </div>
  </div>
</footer>

<style>
  .contact-row {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 10px;
    padding: 0.65rem 0.75rem;
    border-radius: 0.9rem;
    border: 1px solid rgba(12, 124, 78, 0.12);
    background: linear-gradient(135deg, #ffffff, #f9fbff);
    transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease;
  }

  .contact-row:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 26px rgba(12, 41, 60, 0.1);
    border-color: rgba(12, 124, 78, 0.22);
  }

  .contact-cta {
    border-color: rgba(12, 124, 78, 0.22);
    background: linear-gradient(135deg, #f5fbf6, #eef6ff);
  }

  .contact-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: #0d7a4c;
    color: white;
    font-size: 14px;
    font-weight: 700;
  }

  .contact-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #0d7a4c;
  }

  .contact-value {
    font-size: 0.95rem;
    color: #0f172a;
    line-height: 1.35;
  }

  .social-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-width: 34px;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    border: 1px solid #d6dfe6;
    background: #ffffff;
    color: #0f172a;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    transition: transform 120ms ease, border-color 120ms ease, box-shadow 120ms ease;
  }

  .social-pill:hover {
    transform: translateY(-1px);
    border-color: #0d7a4c;
    box-shadow: 0 8px 18px rgba(12, 41, 60, 0.1);
  }

  .social-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: #ffffff;
    background: #0f172a;
  }

  .social-text {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .social-ig {
    border-color: rgba(224, 102, 139, 0.3);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(255, 239, 247, 0.9));
  }

  .social-ig .social-mark {
    background: linear-gradient(135deg, #feda75, #fa7e1e, #d62976, #962fbf, #4f5bd5);
    box-shadow: 0 8px 18px rgba(214, 41, 118, 0.28);
  }

  .social-ig:hover {
    border-color: rgba(214, 41, 118, 0.5);
    box-shadow: 0 10px 24px rgba(214, 41, 118, 0.18);
  }

  .social-fb {
    border-color: rgba(24, 119, 242, 0.3);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(232, 242, 255, 0.9));
  }

  .social-fb .social-mark {
    background: #1877f2;
    box-shadow: 0 8px 18px rgba(24, 119, 242, 0.28);
  }

  .social-fb:hover {
    border-color: rgba(24, 119, 242, 0.5);
    box-shadow: 0 10px 24px rgba(24, 119, 242, 0.18);
  }

  .social-x {
    border-color: rgba(15, 23, 42, 0.25);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(235, 237, 242, 0.9));
  }

  .social-x .social-mark {
    background: #0f172a;
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.24);
  }

  .social-x:hover {
    border-color: rgba(15, 23, 42, 0.45);
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.16);
  }
</style>
